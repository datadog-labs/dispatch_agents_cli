# Dockerfile for remote source builds
# This file is stored in trusted S3 and cannot be modified by users
# Variables will be substituted by build system:
#   BASE_IMAGE - Python base image (e.g., python:3.13-slim)
#   SYSTEM_PACKAGES - Space-separated apt packages to install

ARG BASE_IMAGE=python:3.13-slim
FROM ${BASE_IMAGE}

# Copy uv from official image (recommended method)
COPY --from=ghcr.io/astral-sh/uv:0.5.11 /uv /uvx /bin/

# Install system packages if specified (-- prevents option injection)
ARG SYSTEM_PACKAGES=""
RUN if [ -n "$SYSTEM_PACKAGES" ]; then \
    apt-get update && \
    apt-get install -y --no-install-recommends -- $SYSTEM_PACKAGES && \
    rm -rf /var/lib/apt/lists/*; \
    fi

# Create non-root user for running the agent
# This is required for Claude Agent SDK's bypassPermissions mode to work
# Using a random UID improves isolation between agents running on the same host
# See: https://cookbook.openshift.org/users-and-role-based-access-control/why-do-my-applications-run-as-a-random-user-id.html
ARG USER_UID=1000
RUN useradd --create-home --uid ${USER_UID} --shell /bin/bash dispatch

# Copy agent source code (untrusted user code)
COPY --chown=dispatch:dispatch agent/ /app/
WORKDIR /app

# Install dispatch CLI and SDK from trusted wheels (downloaded by build system from S3)
# Copy to both /tmp (for CLI tools) and /app/dependencies (for uv sync)
COPY dispatch_cli-*.whl dispatch_agents-*.whl /tmp/
RUN pip install --no-cache-dir /tmp/dispatch_cli-*.whl /tmp/dispatch_agents-*.whl

# Run dispatch init to generate .dispatch/ files (listener, Dockerfile, etc)
# This uses the freshly installed CLI, not user-provided files
# Note: schemas.json is already bundled in the source package (pre-generated on user's machine)
RUN echo "Running dispatch agent init..." && \
    ls -la && \
    cat dispatch.yaml 2>/dev/null || cat .dispatch.yaml && \
    dispatch agent init --assume-yes && \
    echo "Verifying init created required files..." && \
    ls -la .dispatch/ && \
    test -f .dispatch/__dispatch_listener__.py || (echo "ERROR: __dispatch_listener__.py not created!" && exit 1)

# Copy trusted wheels to dependencies/ so uv sync uses them instead of PyPI
# This ensures agents use the backend-vetted SDK version, not user-provided
RUN cp /tmp/dispatch_*.whl /app/dependencies/

# Install agent dependencies.
# Dependencies are pre-built as wheels locally (during `dispatch agent deploy`) and
# shipped in dependencies/. uv prefers these over PyPI, preventing untrusted setup.py
# execution for any package that was pre-built.
# uv.lock was removed, so this will regenerate it from pyproject.toml
RUN uv sync --python-preference only-system --find-links /app/dependencies && rm /tmp/*.whl

# Copy entrypoint script (handles MCP config injection)
COPY entrypoint.sh /app/entrypoint.sh
RUN chmod +x /app/entrypoint.sh

# Ensure dispatch user owns all files in /app (including .venv created by uv sync)
RUN chown -R dispatch:dispatch /app

EXPOSE 50051

# Switch to non-root user for runtime
# This enables Claude Agent SDK's bypassPermissions mode
USER dispatch

# schemas.json was already bundled in agent/.dispatch/ from user's machine
# The __dispatch_listener__.py was generated by init above
# Use entrypoint to handle MCP config injection before starting the listener
ENTRYPOINT ["/app/entrypoint.sh"]
