# Base image for Dispatch agents
# Pre-installs uv, dispatch CLI + SDK, and common tooling.
# Built on SDK release and pushed to ECR as dispatchagents/base:{version}
# Agent builds use this via --cache-from to skip repeated setup layers.

ARG PYTHON_IMAGE=python:3.13-slim
FROM ${PYTHON_IMAGE}

# Copy uv from official image
COPY --from=ghcr.io/astral-sh/uv:0.11.2 /uv /uvx /bin/

# Install common system packages that many agents need
RUN apt-get update && \
    apt-get install -y --no-install-recommends git curl && \
    rm -rf /var/lib/apt/lists/*

# Pre-install dispatch CLI and SDK for Docker layer caching.
# Agent builds always overwrite these with backend-provided wheels — this layer
# just ensures cache hits when the SDK version hasn't changed between deploys.
COPY *.whl /tmp/
RUN pip install --no-cache-dir /tmp/*.whl && rm /tmp/*.whl
